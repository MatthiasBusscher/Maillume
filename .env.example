# Inbox Risk Scanner environment example
# Copy this file to .env.local for local development.

# Public/demo deployments should use heuristic mode and should not define
# provider API keys. This avoids maintainer-owned AI costs.
ANALYSIS_MODE=heuristic

# Optional self-hosted AI mode. The provider abstraction exists now;
# actual model calls are implemented in the next AI route issue.
# Set ANALYSIS_MODE=ai, choose a provider, and add your own server-side key.
AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Planned multilingual defaults.
NEXT_PUBLIC_DEFAULT_LOCALE=en
