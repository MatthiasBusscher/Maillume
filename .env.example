# Maillume environment example
# Copy this file to .env.local for local development.

# Optional public URLs. Leave blank for local /app links.
NEXT_PUBLIC_MARKETING_URL=https://maillume.io
NEXT_PUBLIC_APP_URL=https://app.maillume.io

# Optional Supabase Google authentication. Prefer the current publishable key;
# NEXT_PUBLIC_SUPABASE_ANON_KEY remains a legacy fallback. These keys are safe
# for browser use only when Row Level Security and Auth policies are correct.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public/demo deployments should use heuristic mode and should not define
# provider API keys. This avoids maintainer-owned AI costs.
ANALYSIS_MODE=heuristic

# Optional self-hosted AI mode.
# Supported providers: openai, anthropic, openai-compatible.
# For openai-compatible providers, set AI_BASE_URL, AI_API_KEY, and AI_MODEL.
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AI mode requires a model ID. Provider-specific values take precedence over AI_MODEL.
AI_MODEL=
OPENAI_MODEL=
ANTHROPIC_MODEL=
AI_MAX_OUTPUT_TOKENS=800

# Optional AI abuse and cost controls for self-hosted AI mode.
# These are best-effort in-app limits. Also configure provider budgets and
# deployment-level protections for public AI-enabled deployments.
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_MAX_REQUESTS=10
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_MAX_CONCURRENT_REQUESTS=2

# Applies to all hosted analysis requests, including heuristic mode.
ANALYSIS_REQUEST_LIMIT=20
ANALYSIS_REQUEST_WINDOW_SECONDS=60
ANALYSIS_MAX_REQUEST_BYTES=32768

# Optional privacy-safe result feedback.
# Keep disabled when no feedback database is configured. Use memory only for
# local development or browser tests; production rejects memory mode.
FEEDBACK_STORAGE=disabled
SUPABASE_URL=
# Preferred server credential for hosted Supabase projects.
SUPABASE_SECRET_KEY=
# Legacy/self-hosted fallback. Do not configure both unless rotating keys.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Tunnel token used by docker-compose.production.yml.
CLOUDFLARE_TUNNEL_TOKEN=

# Immutable production image selected by the deployment workflow.
MAILLUME_IMAGE=ghcr.io/matthiasbusscher/maillume:latest
